{
  "name": "Robinhood Chain Meme Launchpad & DEX Agent Interface",
  "description": "Integration schema and ABIs for autonomous AI agents to execute trades, deploy tokens, and scan assets on Robinhood Chain L2 with built-in slippage protection.",
  "rpc_endpoints": {
    "robinhood-mainnet": {
      "rpc_url": "https://rpc.mainnet.chain.robinhood.com",
      "chain_id": 4663,
      "explorer": "https://robinhoodchain.blockscout.com"
    },
    "robinhood-testnet": {
      "rpc_url": "https://rpc.testnet.chain.robinhood.com",
      "chain_id": 46630,
      "explorer": "https://explorer.testnet.chain.robinhood.com"
    }
  },
  "contracts": {
    "MemeFactory": {
      "address": "0x322f214995d4808660557F5744Ae8792AE1129cA",
      "abi": [
        {
          "inputs": [
            {"name": "name", "type": "string"},
            {"name": "symbol", "type": "string"},
            {"name": "supply", "type": "uint256"}
          ],
          "name": "deployMemeToken",
          "outputs": [{"name": "", "type": "address"}],
          "stateMutability": "payable",
          "type": "function"
        },
        {
          "inputs": [],
          "name": "getMemeCount",
          "outputs": [{"name": "", "type": "uint256"}],
          "stateMutability": "view",
          "type": "function"
        },
        {
          "inputs": [{"name": "", "type": "uint256"}],
          "name": "allMemeTokens",
          "outputs": [{"name": "", "type": "address"}],
          "stateMutability": "view",
          "type": "function"
        },
        {
          "inputs": [{"name": "tokenAddress", "type": "address"}],
          "name": "buyMemeToken",
          "outputs": [],
          "stateMutability": "payable",
          "type": "function"
        },
        {
          "inputs": [
            {"name": "tokenAddress", "type": "address"},
            {"name": "tokenAmount", "type": "uint256"}
          ],
          "name": "sellMemeToken",
          "outputs": [],
          "stateMutability": "nonpayable",
          "type": "function"
        },
        {
          "inputs": [{"name": "", "type": "address"}],
          "name": "pools",
          "outputs": [
            {"name": "tokenAddress", "type": "address"},
            {"name": "tokenReserves", "type": "uint256"},
            {"name": "ethReserves", "type": "uint256"},
            {"name": "tradingActive", "type": "bool"}
          ],
          "stateMutability": "view",
          "type": "function"
        }
      ]
    },
    "MemeToken": {
      "abi": [
        {
          "constant": true,
          "inputs": [{"name": "_owner", "type": "address"}],
          "name": "balanceOf",
          "outputs": [{"name": "balance", "type": "uint256"}],
          "type": "function"
        },
        {
          "constant": false,
          "inputs": [{"name": "_to", "type": "address"}, {"name": "_value", "type": "uint256"}],
          "name": "transfer",
          "outputs": [{"name": "success", "type": "bool"}],
          "type": "function"
        },
        {
          "constant": false,
          "inputs": [{"name": "_spender", "type": "address"}, {"name": "_value", "type": "uint256"}],
          "name": "approve",
          "outputs": [{"name": "success", "type": "bool"}],
          "type": "function"
        },
        {
          "constant": true,
          "inputs": [],
          "name": "decimals",
          "outputs": [{"name": "", "type": "uint8"}],
          "type": "function"
        },
        {
          "constant": true,
          "inputs": [],
          "name": "symbol",
          "outputs": [{"name": "", "type": "string"}],
          "type": "function"
        }
      ]
    }
  },
  "snippets": {
    "python_slippage_check_example": [
      "from web3 import Web3",
      "",
      "w3 = Web3(Web3.HTTPProvider('https://rpc.mainnet.chain.robinhood.com'))",
      "factory_address = '0x322f214995d4808660557F5744Ae8792AE1129cA'",
      "token_address = '0x...'",
      "factory_abi = [...] # Loaded from MemeFactory ABI above",
      "contract = w3.eth.contract(address=factory_address, abi=factory_abi)",
      "",
      "# 1. Fetch current bonding curve reserves",
      "pool_info = contract.functions.pools(token_address).call()",
      "token_reserves, eth_reserves, trading_active = pool_info[1], pool_info[2], pool_info[3]",
      "",
      "# 2. Calculate pre-flight estimation",
      "eth_spend_wei = w3.to_wei(0.05, 'ether')",
      "k = token_reserves * eth_reserves",
      "new_eth_reserves = eth_reserves + eth_spend_wei",
      "new_token_reserves = k // new_eth_reserves",
      "estimated_tokens = token_reserves - new_token_reserves",
      "",
      "# 3. Enforce maximum 1% slippage check",
      "min_tokens_acceptable = estimated_tokens * 0.99",
      "print(f'Estimated Tokens: {estimated_tokens / 10**18}, Minimum Acceptable: {min_tokens_acceptable / 10**18}')"
    ],
    "python_cross_chain_bridge_example": [
      "import requests",
      "from web3 import Web3",
      "",
      "# Connect to source chain (e.g. Base Mainnet)",
      "src_w3 = Web3(Web3.HTTPProvider('https://mainnet.base.org'))",
      "account = src_w3.eth.account.from_key('YOUR_PRIVATE_KEY')",
      "",
      "# deBridge DLN order creation details",
      "url = 'https://dln.debridge.finance/v1.0/dln/order/create-tx'",
      "params = {",
      "    'srcChainId': 8453, # Base",
      "    'srcChainTokenIn': '0x0000000000000000000000000000000000000000', # ETH",
      "    'srcChainTokenInAmount': '1000000000000000', # 0.001 ETH",
      "    'dstChainId': 4663, # Robinhood Chain",
      "    'dstChainTokenOut': '0x0000000000000000000000000000000000000000', # ETH",
      "    'dstChainTokenOutRecipient': 'YOUR_RECIPIENT_WALLET',",
      "    'srcChainOrderAuthorityAddress': account.address,",
      "    'dstChainOrderAuthorityAddress': 'YOUR_RECIPIENT_WALLET'",
      "}",
      "",
      "# Fetch routing calldata",
      "res = requests.get(url, params=params).json()",
      "tx_payload = res['tx']",
      "",
      "# Build, sign and broadcast transaction on Base",
      "tx = {",
      "    'from': account.address,",
      "    'to': Web3.to_checksum_address(tx_payload['to']),",
      "    'data': tx_payload['data'],",
      "    'value': int(tx_payload['value']),",
      "    'nonce': src_w3.eth.get_transaction_count(account.address),",
      "    'gas': 350000,",
      "    'gasPrice': src_w3.eth.gas_price,",
      "    'chainId': 8453",
      "}",
      "signed_tx = src_w3.eth.account.sign_transaction(tx, private_key=account.key)",
      "tx_hash = src_w3.eth.send_raw_transaction(signed_tx.rawTransaction)",
      "print(f'Bridge order submitted on Base! Tx: {src_w3.to_hex(tx_hash)}')"
    ]
  }
}
